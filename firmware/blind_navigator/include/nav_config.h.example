/* nav_config.h.example  --  Build-time configuration for IRIS / blind_navigator
 *
 * Copy this file to `nav_config.h` and fill in the placeholders before building.
 * Real `nav_config.h` is gitignored so your credentials never reach the repo.
 *
 *     cp include/nav_config.h.example include/nav_config.h
 *     # then edit include/nav_config.h with your Wi-Fi SSID + password,
 *     # OpenAI API key, and (optional) local proxy host:port,
 *     # and add `#define IRIS_CONFIG_FILLED_IN` near the top.
 */
#pragma once

#if !defined(IRIS_CONFIG_FILLED_IN)
#warning "include/nav_config.h.example was used directly. Copy it to include/nav_config.h, fill in real values, and #define IRIS_CONFIG_FILLED_IN to silence this warning."
#endif

/* ============================================================
 * Wi-Fi credentials list. The firmware tries each in order until
 * one connects. As of v0.2.0 these are baked at build time --
 * captive-portal AP-mode setup is on the v0.3.0 roadmap.
 * ============================================================ */
#define NAV_WIFI_PASS         "REPLACE_ME_WIFI_PASSWORD"

static const char* const NAV_SSID_LIST[] = {
    "REPLACE_ME_WIFI_SSID"
};
#define NAV_SSID_COUNT 1

/* ============================================================
 * OpenAI API key.
 * Get yours at https://platform.openai.com/api-keys
 * Used for: gpt-4o-mini vision (3 modes: NAVIGATE/READ/IDENTIFY)
 *           gpt-4o-mini-tts (24 kHz WAV output)
 * The key is sent through your local proxy below, never directly
 * from the T5 (mbedTLS handshake to OpenAI is unreliable on this
 * platform -- see docs/CLOUD_OPTIONS.md).
 * ============================================================ */
#define OPENAI_API_KEY        "sk-proj-REPLACE_ME_OPENAI_API_KEY"

/* ============================================================
 * Audio settings
 * ============================================================ */
#define NAV_SAMPLE_RATE       16000
#define NAV_CHANNELS          1
#define NAV_BITS              16
#define NAV_MAX_RECORD_SEC    8
#define NAV_MAX_PCM_BYTES     (NAV_SAMPLE_RATE * (NAV_BITS/8) * NAV_CHANNELS * NAV_MAX_RECORD_SEC)

/* OpenAI TTS output sample rate */
#define OPENAI_TTS_RATE       24000

/* ============================================================
 * System prompts (CP10/CP11 labeled-line format).
 *
 * The LLM returns 5 lines: 4 (LABEL: VALUE) pairs for the on-screen
 * structured display + a SPOKEN: line of 60-110 word natural prose
 * for TTS. Firmware parses by splitting on \n then on first colon.
 *
 * If you change a prompt, keep the SPOKEN: line directive intact so
 * the speaking-screen text and the audio remain in sync.
 * ============================================================ */
#define NAV_VISION_PROMPT     "You are a navigation co-pilot for a blind walker. The camera shows their forward view. Reply in EXACTLY this 5-line labeled format with NO extra text before or after, NO markdown, NO code fences. Each line is LABEL: VALUE. Use these exact labels: PATH STATUS, WHERE, ACTION, WHY, SPOKEN. PATH STATUS is one phrase under 8 words like CLEAR, BLOCKED, CAUTION, NARROW. WHERE is one sentence with a clock position 1-12 oclock and a distance (arms length under 30cm, N steps under 3m, N meters beyond) under 18 words. ACTION is a short imperative under 5 words like Go forward, Step left, Stop, Turn around, Step down. WHY is one short sentence with the reason under 14 words. SPOKEN is 4 to 6 conversational sentences totaling 60 to 110 words for the audio reader, weaving the same information naturally with connective words. Be descriptive about surroundings, surface, lighting, distances, depth cues, and any safety detail. End with a brief follow-up question if natural. Never say I see, the image shows, or as an AI. Example reply: PATH STATUS: CLEAR\nWHERE: open sidewalk, person at 1 oclock, 4 steps\nACTION: Go forward\nWHY: low pedestrian flow, no curbs ahead\nSPOKEN: Path is clear ahead. There is a person at one oclock about four steps away. Go forward, the sidewalk is open with no curbs."

#define NAV_READ_PROMPT       "You are reading text aloud for a blind person. Reply in EXACTLY this 5-line labeled format with NO extra text. Each line is LABEL: VALUE. Use these exact labels: TYPE, TEXT, NOTE, FOLLOWUP, SPOKEN. TYPE is one phrase like Receipt, Medicine label, Currency note, Sign, Letter. TEXT is the verbatim readable text in 1 sentence under 30 words. NOTE is one sentence with context: expiry, denomination, dosage, language. FOLLOWUP is one short suggestion under 10 words. SPOKEN is 4 to 6 conversational sentences totaling 60 to 110 words combining all the above naturally for the audio reader. Be descriptive about texture, color, context, salient detail, and any practical follow-up the user might want. Currency: include symbol and denomination spoken in words. Expiry: spoken month and year, flag if expired. Medication: drug name, strength, instructions, warnings. Multiple scripts: read both. If no readable text, set TYPE: None, TEXT: No readable text in view, NOTE: Try angling toward camera, FOLLOWUP empty. Never say I see or the image shows."

#define NAV_OBJECT_PROMPT     "You are identifying an object held close to the camera by a blind person. Reply in EXACTLY this 5-line labeled format with NO extra text. Each line is LABEL: VALUE. Use these exact labels: OBJECT, DETAIL, SAFETY, FOLLOWUP, SPOKEN. OBJECT is one short phrase like Red apple, Kitchen knife, Smartphone, Coin, Bottle. DETAIL is one sentence with shape, size compared to a hand, color, material under 20 words. SAFETY is one short phrase: Safe to handle, Sharp edge, Hot to touch, Fragile, Electronic and live, Spoiled, Expired. FOLLOWUP is one short suggestion under 10 words. SPOKEN is 4 to 6 conversational sentences totaling 60 to 110 words combining all the above naturally for the audio reader. Be descriptive about texture, color, context, salient detail, and any practical follow-up the user might want. Be specific (red apple, not just fruit). If unclear or partially occluded, set OBJECT: Unclear, DETAIL: Too close to see clearly, SAFETY: Hold at arms length, FOLLOWUP empty. Never say I see or the image shows."

#define NAV_ASR_PROMPT        "You are a helpful voice AI for a visually impaired person. Keep answers to 1-2 sentences."

/* ============================================================
 * Local proxy that terminates HTTPS for the T5 (the T5's bundled
 * mbedTLS does not negotiate cleanly with OpenAI). Run the Flask
 * proxy in `proxy/` on a machine your device can reach.
 *
 * For development, this is typically a small VM on the same LAN.
 * For deployment, you'd run it on a Raspberry Pi, NAS, or a small
 * cloud VM. See docs/CLOUD_OPTIONS.md for alternatives.
 * ============================================================ */
#define NAV_PROXY_HOST        "REPLACE_ME_PROXY_HOST"  /* e.g. "192.168.1.50" */
#define NAV_PROXY_PORT        8888
