CONFIG_PROJECT_VERSION="1.0.2"
CONFIG_TUYA_PRODUCT_ID="9inb01mvjqh5zhhr"
CONFIG_ENABLE_AI_UI_TEXT_STREAMING=y
CONFIG_ENABLE_COMP_AI_AUDIO_CODEC_OPUS=y
CONFIG_ENABLE_COMP_AI_VIDEO=y
CONFIG_BUTTON_NAME="ai_chat_button"
CONFIG_BOARD_CHOICE_T5AI=y
CONFIG_TUYA_T5AI_BOARD_EX_MODULE_35565LCD=y
CONFIG_ENABLE_EX_MODULE_CAMERA=y
CONFIG_AI_INPUT_STACK_SIZE=28672
CONFIG_ENABLE_TUYA_CODEC_OPUS=y
# CONFIG_ENABLE_TUYA_CODEC_OPUS_IPC is not set
CONFIG_ENABLE_MBEDTLS_SSL_MAX_CONTENT_LEN=4096
CONFIG_LVGL_ENABLE_TP=y
CONFIG_COMP_AI_VIDEO_WIDTH=480
CONFIG_COMP_AI_VIDEO_HEIGHT=480
CONFIG_COMP_AI_VIDEO_FPS=15
CONFIG_ENABLE_COMP_AI_VIDEO_JPEG_QUALITY=y
CONFIG_COMP_AI_VIDEO_JPEG_QUALITY_MAX_SIZE=60
CONFIG_COMP_AI_VIDEO_JPEG_QUALITY_MIN_SIZE=10

# === CP12: wake word + audio input + alerts + English language ===
CONFIG_ENABLE_AI_LANGUAGE_ENGLISH=y
# CONFIG_ENABLE_AI_LANGUAGE_CHINESE is not set
CONFIG_ENABLE_COMP_AI_AUDIO=y
CONFIG_ENABLE_COMP_AI_MODE_WAKEUP=y
CONFIG_AI_PLAYER_ALERT_SOURCE_LOCAL=y
CONFIG_ENABLE_WAKEUP=y
CONFIG_ENABLE_AI_PLAYER=y
